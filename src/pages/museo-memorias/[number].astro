export const getStaticPaths: GetStaticPaths = () => {
  const allProyectos = [
    { number: 30, title: "LIBRE" },
    { number: 29, title: "Cartografías de Memorias de las luchas vecinales de Entrevías, El Pozo y Palomeras Bajas" },
    { number: 28, title: "Retratos y objetos de los patrimonios de memoria y construcción de paz" },
    { number: 27, title: "Políticas culturales de memoria en la Dirección de Patrimonio y Memoria" },
    { number: 26, title: "Herramientas digitales para combatir el memoricidio: memoria de la Nakba y narrativas palestinas" },
    { number: 25, title: "Cuerpos que Resiten" },
    { number: 24, title: "El elocuente silencio del paisaje" },
    { number: 22, title: "Escuela Iberoamericana de Mediación en sitios y Museos de Memoria" },
    { number: 21, title: "Lorca con orgullo VR" },
    { number: 20, title: "Encuentro Intergeneracional de Memoria(s) en el parque de la Memoria de Sartaguda" },
    { number: 19, title: "Las Otras Memorias" },
    { number: 18, title: "La Madeja: Exposición Fotográfica Mujer Rural" },
    { number: 16, title: "El territorio en las cosas" },
    { number: 15, title: "Herstóricas: memorias desde lo colectivo" },
    { number: 14, title: "¡Reproduzca Expansivamente!" },
    { number: 13, title: "Palimpsestos Paralelos: Barrios en Transformación a Través de la Mirada de Niñes" },
    { number: 12, title: "Muro de la Presencia" },
    { number: 11, title: "Amoratorio de Creación: Cenizas, Flores y Faroles para No Olvidar" },
    { number: 10, title: "Radio Almaina, 15 Años de Radio Libre en Granada" },
    { number: 9, title: "Proyecto Etno Vega (s)" },
    { number: 8, title: "Historias Inconclusas" },
    { number: 7, title: "Sabedores RA" },
    { number: 6, title: "Proyecto de Memoria Juvenil «Ruta al Exilio»" },
    { number: 5, title: "Proyecto 6402+" },
    { number: 4, title: "PuebloAgua, Universo Anfibio" },
    { number: 3, title: "Sal y Surco: Retrato y territorio" },
    { number: 1, title: "Exposición de Arte Sacro-Social «San Miguel Harto»" },
  ];
  return allProyectos.map(p => ({
    params: { number: p.number.toString() },
    props: {},
  }));
};

const { number } = Astro.params;
const proyecto = proyectos.find(p => p.number === Number(number));

if (!proyecto) {
  return Astro.redirect('/museo-memorias');
}

// Find prev/next projects
const currentIndex = proyectos.findIndex(p => p.number === Number(number));
const prevProject = currentIndex < proyectos.length - 1 ? proyectos[currentIndex + 1] : null;
const nextProject = currentIndex > 0 ? proyectos[currentIndex - 1] : null;
---

<Layout title={`${proyecto.title} - Museo de Memorias Vivas`}>
  <!-- Hero -->
  <section class="relative h-[30vh] min-h-[250px] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0">
      <img 
        src="/images/hero-bg.jpg" 
        alt="Museo de Memorias Vivas" 
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-black/60"></div>
    </div>
    <div class="relative z-10 text-center px-4">
      <nav class="text-white/70 text-sm mb-4">
        <a href="/" class="hover:text-white transition-colors">Inicio</a>
        <span class="mx-2">/</span>
        <a href="/museo-memorias" class="hover:text-white transition-colors">Museo de Memorias Vivas</a>
        <span class="mx-2">/</span>
        <span class="text-white">{proyecto.number}. {proyecto.title}</span>
      </nav>
      <h1 class="text-3xl md:text-4xl font-bold text-white font-[family-name:var(--font-heading)] drop-shadow-lg max-w-4xl mx-auto">
        {proyecto.number}. {proyecto.title}
      </h1>
    </div>
  </section>

  <!-- Contenido del proyecto -->
  <section class="py-12 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <!-- Imagen del proyecto -->
      <div class="mb-8">
        <img 
          src={proyecto.fullImage} 
          alt={proyecto.title}
          class="w-full rounded-xl shadow-lg"
        />
      </div>

      <!-- Metadatos -->
      <div class="flex flex-wrap gap-4 mb-8 text-sm">
        <div class="flex items-center gap-2 text-ugr-green">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          <span>{proyecto.place}</span>
        </div>
        {proyecto.author && (
          <div class="flex items-center gap-2 text-ugr-text-light">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
            <span>{proyecto.author}</span>
          </div>
        )}
        {proyecto.collective && (
          <div class="flex items-center gap-2 text-ugr-text-light">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
            </svg>
            <span>{proyecto.collective}</span>
          </div>
        )}
      </div>

      <!-- Descripción -->
      <div class="prose prose-lg max-w-none">
        {proyecto.description.split('\n\n').map(paragraph => (
          <p class="text-ugr-text leading-relaxed mb-4">{paragraph}</p>
        ))}
      </div>

      <!-- Navegación entre proyectos -->
      <div class="mt-12 pt-8 border-t border-gray-200">
        <div class="flex justify-between items-center">
          {prevProject ? (
            <a 
              href={`/museo-memorias/${prevProject.number}`}
              class="flex items-center gap-2 text-ugr-green hover:text-ugr-green-light transition-colors"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
              </svg>
              <span class="hidden sm:inline">Anterior: {prevProject.number}. {prevProject.title.substring(0, 30)}...</span>
              <span class="sm:hidden">Anterior</span>
            </a>
          ) : <div />}
          
          <a 
            href="/museo-memorias"
            class="text-ugr-green hover:text-ugr-green-light transition-colors"
          >
            Volver al Museo
          </a>

          {nextProject ? (
            <a 
              href={`/museo-memorias/${nextProject.number}`}
              class="flex items-center gap-2 text-ugr-green hover:text-ugr-green-light transition-colors"
            >
              <span class="hidden sm:inline">Siguiente: {nextProject.number}. {nextProject.title.substring(0, 30)}...</span>
              <span class="sm:hidden">Siguiente</span>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          ) : <div />}
        </div>
      </div>
    </div>
  </section>
</Layout>
