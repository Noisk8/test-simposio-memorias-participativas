---
import Layout from '../../layouts/Layout.astro';
import type { GetStaticPaths } from 'astro';

const proyectos = [
  { 
    number: 30, 
    title: "LIBRE", 
    place: "Estado español", 
    image: "/images/proyecto-30.jpg",
    fullImage: "/images/proyecto-30.jpg",
    author: "Fernando Sánchez Castillo",
    collective: "Comisionado 50 años de España en Libertad",
    description: "Libre invita a reflexionar sobre el papel del arte como herramienta de diálogo y construcción colectiva: una propuesta que convierte la memoria en acción y el pasado en una oportunidad para imaginar futuros más libres y compartidos.\n\nFernando Sánchez Castillo crea Libre, una instalación que reúne 25.000 réplicas de la estatua ecuestre del dictador Francisco Franco, realizadas con motivo de los 50 años de España en libertad y presentadas esta vez sin jinete. Más de 3.000 personas pudieron llevarse una de esas miniaturas a cambio de dejar un mensaje escrito (palabras, dibujos o reflexiones en torno a la libertad, la democracia o los derechos fundamentales) que se integra a un gran mural colectivo. Con esta acción, Libre se convierte en una metáfora viva de la democracia participativa: los símbolos del poder se transforman en espacios compartidos de memoria y pensamiento."
  },
  { 
    number: 29, 
    title: "Cartografías de Memorias de las luchas vecinales de Entrevías, El Pozo y Palomeras Bajas", 
    place: "Madrid, Estado español", 
    image: "/images/proyecto-29.jpg",
    fullImage: "/images/proyecto-29.jpg",
    author: "Sara Martín Terceño",
    collective: "Celebración de los 50 años de España en Libertad y La Liminal",
    description: "Durante el tardofranquismo y la transición, muchos barrios obreros de España se convirtieron en espacios esenciales de organización colectiva y aprendizaje ciudadano. Desde sus asociaciones vecinales impulsaron mejoras urbanas, fortalecieron redes de apoyo y se convirtieron en escuelas de democracia en un contexto sin libertades.\n\nCentrado en 3 barrios periféricos de Madrid, el proyecto recoge esta historia cruzando el territorio con la memoria oral, para dar forma a una cartografía que localiza espacios de reunión, lucha y conquista ciudadana y recoge relatos orales del vecindario. La iniciativa activa memorias locales, reconoce el papel de las mujeres y pone en valor estos patrimonios comunitarios."
  },
  { 
    number: 28, 
