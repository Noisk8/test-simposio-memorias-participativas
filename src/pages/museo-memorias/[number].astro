---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const proyectos = await getCollection('proyectos');
  return proyectos.map((entry) => ({
    params: { number: entry.data.number.toString() },
    props: { entry },
  }));
};

const { entry } = Astro.props;
const { Content } = await render(entry);
const proyecto = entry.data;

// Proyectos adyacentes para navegación
const todos = await getCollection('proyectos');
const ordenados = todos.sort((a, b) => b.data.number - a.data.number);
const idx = ordenados.findIndex((e) => e.data.number === proyecto.number);
const prevProject = idx < ordenados.length - 1 ? ordenados[idx + 1] : null;
const nextProject = idx > 0 ? ordenados[idx - 1] : null;
---

<Layout title={`${proyecto.title} - Museo de Memorias Vivas`}>
  <!-- Hero -->
  <section class="relative h-[30vh] min-h-[250px] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0">
      <img 
        src="/images/hero-bg.jpg" 
        alt="Museo de Memorias Vivas" 
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-black/60"></div>
    </div>
    <div class="relative z-10 text-center px-4">
      <nav class="text-white/70 text-sm mb-4">
        <a href="/" class="hover:text-white transition-colors">Inicio</a>
        <span class="mx-2">/</span>
        <a href="/museo-memorias/" class="hover:text-white transition-colors">Museo de Memorias Vivas</a>
        <span class="mx-2">/</span>
        <span class="text-white">{proyecto.number}. {proyecto.title}</span>
      </nav>
      <h1 class="text-3xl md:text-4xl font-bold text-white font-[family-name:var(--font-heading)] drop-shadow-lg max-w-4xl mx-auto">
        {proyecto.number}. {proyecto.title}
      </h1>
    </div>
  </section>

  <!-- Contenido del proyecto -->
  <section class="py-12 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <!-- Imagen del proyecto -->
      <div class="mb-8">
        <img 
          src={proyecto.image} 
          alt={proyecto.title}
          class="w-full rounded-xl shadow-lg"
        />
      </div>

      <!-- Metadatos -->
      <div class="flex flex-wrap gap-4 mb-8 text-sm">
        <div class="flex items-center gap-2 text-ugr-green">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          <span>{proyecto.place}</span>
        </div>
        {proyecto.author && (
          <div class="flex items-center gap-2 text-ugr-text-light">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
            <span>{proyecto.author}</span>
          </div>
        )}
        {proyecto.collective && (
          <div class="flex items-center gap-2 text-ugr-text-light">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <span>{proyecto.collective}</span>
          </div>
        )}
      </div>

      <!-- Descripción corta -->
      {proyecto.description && (
        <p class="text-lg text-ugr-text leading-relaxed mb-6 font-medium border-l-4 border-ugr-green pl-4">
          {proyecto.description}
        </p>
      )}

      <!-- Cuerpo en markdown -->
      <div class="prose prose-lg max-w-none text-ugr-text prose-headings:text-ugr-green-dark prose-a:text-ugr-green">
        <Content />
      </div>

      <!-- Navegación entre proyectos -->
      <div class="mt-12 pt-8 border-t border-gray-200 flex flex-col sm:flex-row gap-4 justify-between">
        {prevProject && (
          <a 
            href={`/museo-memorias/${prevProject.data.number}`}
            class="flex items-center gap-3 text-ugr-green hover:text-ugr-green-dark transition-colors group"
          >
            <span class="text-2xl">←</span>
            <div>
              <p class="text-xs text-ugr-text-light uppercase tracking-wide mb-1">Proyecto anterior</p>
              <p class="font-semibold line-clamp-1 group-hover:underline">{prevProject.data.title}</p>
            </div>
          </a>
        )}
        {nextProject && (
          <a 
            href={`/museo-memorias/${nextProject.data.number}`}
            class="flex items-center gap-3 text-ugr-green hover:text-ugr-green-dark transition-colors group sm:text-right sm:flex-row-reverse"
          >
            <span class="text-2xl">→</span>
            <div>
              <p class="text-xs text-ugr-text-light uppercase tracking-wide mb-1">Proyecto siguiente</p>
              <p class="font-semibold line-clamp-1 group-hover:underline">{nextProject.data.title}</p>
            </div>
          </a>
        )}
      </div>

      <!-- Volver al museo -->
      <div class="mt-8 text-center">
        <a href="/museo-memorias/" class="btn-green inline-block px-6 py-3">
          ← Volver al Museo de Memorias Vivas
        </a>
      </div>
    </div>
  </section>
</Layout>
