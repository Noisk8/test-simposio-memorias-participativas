---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const todos = await getCollection('proyectos');
  const ordenados = todos.sort((a, b) => b.data.number - a.data.number);
  return paginate(ordenados, { pageSize: 10 });
};

const { page } = Astro.props;
const proyectos = page.data;
const totalPages = page.lastPage;
const currentPage = page.currentPage;
---

<Layout title={`Museo de Memorias Vivas — Página ${currentPage} - I Simposio sobre Memorias Participativas`}>
  <!-- Hero -->
  <section class="relative h-[40vh] min-h-[300px] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0">
      <img 
        src="/images/hero-bg.jpg" 
        alt="I Simposio sobre Memorias Participativas" 
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-black/60"></div>
    </div>
    <div class="relative z-10 text-center px-4">
      <nav class="text-white/70 text-sm mb-4">
        <a href="/" class="hover:text-white transition-colors">Inicio</a>
        <span class="mx-2">/</span>
        <a href="/museo-memorias/" class="hover:text-white transition-colors">Museo de Memorias Vivas</a>
        <span class="mx-2">/</span>
        <span class="text-white">Página {currentPage}</span>
      </nav>
      <h1 class="text-4xl md:text-5xl font-bold text-white font-[family-name:var(--font-heading)] drop-shadow-lg">
        Museo de Memorias Vivas
      </h1>
    </div>
  </section>

  <!-- Coordinación -->
  <section class="py-8 bg-ugr-cream border-b">
    <div class="max-w-5xl mx-auto px-4">
      <p class="text-ugr-text text-center">
        <strong class="text-ugr-green-dark">Coordinación de curaduría y museografía:</strong> Natalia Luc<br/>
        <strong class="text-ugr-green-dark">Co-curaduría:</strong> Natalia Luc, Diana Castelblanco, Sorany Marín, Andrés Góngora y Johana Botero
      </p>
    </div>
  </section>

  <!-- Grid de proyectos -->
  <section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {proyectos.map((entry) => (
          <a 
            href={`/museo-memorias/${entry.data.number}`}
            class="block card-shadow bg-white rounded-xl overflow-hidden border border-gray-100 hover:border-ugr-green/30 transition-all duration-300 group"
          >
            <div class="relative h-48 overflow-hidden">
              <img 
                src={entry.data.image} 
                alt={entry.data.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              />
              <div class="absolute top-3 left-3">
                <span class="bg-ugr-green text-white text-xs font-bold px-3 py-1 rounded-full">
                  {entry.data.number}
                </span>
              </div>
            </div>
            <div class="p-5">
              <h3 class="text-lg font-bold text-ugr-green-dark mb-2 font-[family-name:var(--font-heading)] line-clamp-2">
                {entry.data.title}
              </h3>
              <p class="text-xs text-ugr-green-light mb-2 font-semibold uppercase tracking-wide">
                {entry.data.place}
              </p>
              <p class="text-sm text-ugr-text-light line-clamp-3">
                {entry.data.description}
              </p>
              <p class="text-xs text-ugr-text-light mt-3 italic">
                {entry.data.author || entry.data.collective}
              </p>
            </div>
          </a>
        ))}
      </div>

      <!-- Paginación -->
      <nav class="mt-12 flex justify-center items-center gap-2">
        {page.url.prev && (
          <a href={page.url.prev} class="btn-green px-4 py-2 text-sm">
            ← Anterior
          </a>
        )}
        {Array.from({ length: totalPages }, (_, i) => i + 1).map((p) => (
          <a
            href={p === 1 ? '/museo-memorias/' : `/museo-memorias/page/${p}`}
            class={`w-10 h-10 flex items-center justify-center rounded-lg font-semibold transition-all duration-300 ${
              p === currentPage
                ? 'bg-ugr-green text-white shadow-md'
                : 'bg-gray-100 text-ugr-green hover:bg-ugr-green/10'
            }`}
          >
            {p}
          </a>
        ))}
        {page.url.next && (
          <a href={page.url.next} class="btn-green px-4 py-2 text-sm">
            Siguiente →
          </a>
        )}
      </nav>
    </div>
  </section>
</Layout>
