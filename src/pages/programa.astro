---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Programa - I Simposio sobre Memorias Participativas">
  <!-- Hero -->
  <section class="relative h-[40vh] min-h-[300px] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0">
      <img 
        src="/images/hero-bg.jpg" 
        alt="I Simposio sobre Memorias Participativas" 
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-black/60"></div>
    </div>
    <div class="relative z-10 text-center px-4">
      <nav class="text-white/70 text-sm mb-4">
        <a href="/" class="hover:text-white transition-colors">Inicio</a>
        <span class="mx-2">/</span>
        <span class="text-white">Programa</span>
      </nav>
      <h1 class="text-4xl md:text-5xl font-bold text-white font-[family-name:var(--font-heading)] drop-shadow-lg">
        Programa
      </h1>
    </div>
  </section>

  <!-- Contenido -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-10 text-ugr-green-dark font-[family-name:var(--font-heading)]">
        Programa
      </h2>
      
      <!-- Imagen del programa -->
      <div class="card-shadow rounded-xl overflow-hidden inline-block mb-8">
        <img 
          src="/images/programa.jpg" 
          alt="Programa del I Simposio sobre Memorias Participativas" 
          class="w-full max-w-2xl mx-auto hover:scale-[1.02] transition-transform duration-500"
        />
      </div>
      
      <!-- Enlace de descarga -->
      <div class="mt-8">
        <p class="text-lg text-ugr-text mb-6">
          Descarga el programa completo
        </p>
        <a 
          href="https://drive.google.com/file/d/1VZXl74sKm6vBJ-KJJnDrBSHTmyGb2X47/view?usp=drive_link" 
          target="_blank" 
          rel="noopener noreferrer"
          class="btn-green inline-flex items-center gap-2 text-lg"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          Descarga el programa aquí
        </a>
      </div>
    </div>
  </section>
</Layout>
