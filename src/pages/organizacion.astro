---
import Layout from '../layouts/Layout.astro';

const organizadores = [
  { nombre: "Andrea García González", institucion: "Universidad de Granada (UGR), Marie Sklodowska-Curie fellow" },
  { nombre: "Jordi Guixé", institucion: "EUROM, Universidad de Barcelona (UB)" },
  { nombre: "Carmina Gustrán Loscos", institucion: "Comisionada \"50 años de España en Libertad\"" },
  { nombre: "José Miguel Gastón Aguas", institucion: "Instituto Navarro de Memoria" },
  { nombre: "Carla Alba Pulido", institucion: "UGR" },
  { nombre: "Vanesa Garbero", institucion: "EUROM, Universidad Nacional de Córdoba y CONICET, Argentina" },
  { nombre: "Diana Castelblanco", institucion: "Universidad Jorge Tadeo Lozano, Colombia" },
  { nombre: "Marian del Moral", institucion: "UGR" },
  { nombre: "Sorany Marin", institucion: "Universidad Magdalena, Colombia" },
  { nombre: "Anna Pastor", institucion: "EUROM, UB" },
  { nombre: "Carmen Gregorio Gil", institucion: "UGR" },
  { nombre: "Victoria Robles", institucion: "UGR" },
  { nombre: "Ascensión Mazuela", institucion: "UGR" },
  { nombre: "Natalia Luc", institucion: "UGR" },
  { nombre: "Enrique Tudela", institucion: "UGR" },
  { nombre: "Jesús Rodríguez Huertas", institucion: "UGR" },
  { nombre: "Miguel Ángel del Arco", institucion: "UGR" },
  { nombre: "David González", institucion: "EUROM, UB" },
  { nombre: "Johana Botero Ramírez", institucion: "Wikimedia Colombia" },
  { nombre: "Astrid Jamar", institucion: "Universidad de Antwerp, Bélgica" },
  { nombre: "Andrés Góngora", institucion: "Universidad Nacional de Colombia y Museo Nacional de Colombia" },
  { nombre: "Daniela Güiza", institucion: "Viceministerio de los Patrimonios, las Memorias y Gobernanza Cultural, Colombia" },
  { nombre: "Alejandro Castillejo", institucion: "Universidad de los Andes, Colombia" },
  { nombre: "José Fernando Serrano", institucion: "Universidad de los Andes, Colombia" },
  { nombre: "Adolfo Baltar", institucion: "Universidad Tecnológica de Bolívar, Cartagena, Colombia" },
  { nombre: "Olatz Dañobeitia", institucion: "Universidad del País Vasco" },
  { nombre: "Iñaki Sagardoi", institucion: "Universidad Pública de Navarra" },
  { nombre: "Dario Ranocchiari", institucion: "UGR" },
  { nombre: "Kitti Baracsi", institucion: "Centro em Rede de Investigação em Antropologia, Lisboa" },
];
---

<Layout title="Organización - I Simposio sobre Memorias Participativas">
  <!-- Hero -->
  <section class="relative h-[40vh] min-h-[300px] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0">
      <img 
        src="/images/hero-bg.jpg" 
        alt="I Simposio sobre Memorias Participativas" 
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-black/60"></div>
    </div>
    <div class="relative z-10 text-center px-4">
      <nav class="text-white/70 text-sm mb-4">
        <a href="/" class="hover:text-white transition-colors">Inicio</a>
        <span class="mx-2">/</span>
        <span class="text-white">Organización</span>
      </nav>
      <h1 class="text-4xl md:text-5xl font-bold text-white font-[family-name:var(--font-heading)] drop-shadow-lg">
        Organización
      </h1>
    </div>
  </section>

  <!-- Lista de organizadores -->
  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {organizadores.map((org) => (
          <div class="card-shadow bg-white rounded-xl p-5 border-l-4 border-ugr-green hover:border-ugr-green-light transition-all duration-300">
            <h3 class="font-bold text-ugr-green-dark mb-1 font-[family-name:var(--font-heading)]">
              {org.nombre}
            </h3>
            <p class="text-sm text-ugr-text-light">
              {org.institucion}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Instituciones organizadoras -->
  <section class="py-16 bg-ugr-cream">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-10 text-ugr-green-dark font-[family-name:var(--font-heading)]">
        Instituciones organizadoras
      </h2>
      <div class="card-shadow rounded-xl overflow-hidden inline-block bg-white p-4">
        <img 
          src="/images/organizacion-logos.jpg" 
          alt="Instituciones organizadoras del I Simposio sobre Memorias Participativas" 
          class="w-full max-w-2xl mx-auto"
        />
      </div>
    </div>
  </section>
</Layout>
