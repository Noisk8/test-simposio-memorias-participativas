---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'I Simposio sobre Memorias Participativas - Universidad de Granada' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <script src="https://identity.netlify.com/v1/netlify.js"></script>
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <script is:inline>
      // Integración con Netlify Identity para el acceso al gestor de contenido (/admin/).
      // El widget se carga desde <head>; esperamos a que window.netlifyIdentity exista
      // antes de registrar los manejadores (por si el script aún no terminó de cargar).
      (function initNetlifyIdentity() {
        if (!window.netlifyIdentity) {
          document.addEventListener('DOMContentLoaded', initNetlifyIdentity, { once: true });
          return;
        }

        const identity = window.netlifyIdentity;

        identity.on('init', (user) => {
          const hash = window.location.hash;
          // Los correos de invitación y de recuperación de contraseña enlazan a la
          // raíz del sitio con el token en el hash. Abrimos el modal para completarlos.
          if (hash && (hash.includes('invite_token=') || hash.includes('recovery_token='))) {
            identity.open();
          }
        });

        // Al iniciar sesión correctamente, llevar al editor al panel del CMS.
        identity.on('login', () => {
          document.location.href = '/admin/';
        });

        // Al cerrar sesión, volver a la portada.
        identity.on('logout', () => {
          document.location.href = '/';
        });
      })();
    </script>
  </body>
</html>
