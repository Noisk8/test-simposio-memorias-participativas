---
---

<header class="bg-white sticky top-0 z-50 overflow-hidden">
  <!-- Fila 1: Franja arcoíris + Logos -->
  <div class="flex items-stretch">
    <!-- Franja arcoíris vertical -->
    <div class="flex flex-col w-3 flex-shrink-0">
      <div class="flex-1 bg-[#e40303]"></div>
      <div class="flex-1 bg-[#ff8c00]"></div>
      <div class="flex-1 bg-[#ffed00]"></div>
      <div class="flex-1 bg-[#008026]"></div>
      <div class="flex-1 bg-[#004dff]"></div>
      <div class="flex-1 bg-[#750787]"></div>
    </div>

    <!-- Contenido del header -->
    <div class="flex-1 max-w-7xl mx-auto flex items-center justify-between px-4 md:px-8 py-2 gap-4">
      <!-- Logo UGR -->
      <a href="https://www.ugr.es" target="_blank" rel="noopener noreferrer" class="flex-shrink-0 hover:opacity-90 transition-opacity">
        <img 
          src="/images/logologo.png" 
          alt="Universidad de Granada" 
          class="!h-8 md:!h-10 lg:!h-12 w-auto !max-w-[100px] md:!max-w-[130px] lg:!max-w-[160px]"
        />
      </a>

      <!-- Logo EUROM -->
      <a href="https://eurom.ub.edu" target="_blank" rel="noopener noreferrer" class="flex-shrink-0 hover:opacity-90 transition-opacity">
        <img 
          src="/images/logo-eurom-real.jpg" 
          alt="EUROM - European Observatory on Memories" 
          class="!h-8 md:!h-10 lg:!h-12 w-auto !max-w-[100px] md:!max-w-[130px] lg:!max-w-[160px]"
        />
      </a>
    </div>
  </div>

  <!-- Fila 2: Título + Navegación -->
  <div class="border-t border-gray-200">
    <div class="max-w-7xl mx-auto px-4 md:px-8 py-3 flex flex-col md:flex-row md:items-center md:justify-between gap-3">
      <!-- Título del simposio -->
      <a href="/" class="flex-shrink-0">
        <h1 class="text-base md:text-lg lg:text-xl font-bold text-ugr-green leading-tight font-[family-name:var(--font-heading)] tracking-tight">
          I SIMPOSIO SOBRE MEMORIAS PARTICIPATIVAS
        </h1>
      </a>

      <!-- Navegación -->
      <nav class="flex-1">
        <!-- Botón menú móvil -->
        <button 
          id="mobile-menu-btn"
          class="md:hidden text-ugr-green p-2 rounded-lg hover:bg-ugr-green/10 transition-colors ml-auto block"
          aria-label="Menú"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>

        <!-- Navegación desktop -->
        <ul id="main-nav" class="hidden md:flex md:items-center md:gap-1 md:flex-wrap md:justify-end">
          <li>
            <a href="/" class="block px-3 py-2 rounded-md text-sm font-semibold text-ugr-green hover:bg-ugr-green hover:text-white transition-all duration-200">
              Inicio
            </a>
          </li>
          <li>
            <a href="/el-simposio" class="block px-3 py-2 rounded-md text-sm font-semibold text-ugr-green hover:bg-ugr-green hover:text-white transition-all duration-200">
              El Simposio
            </a>
          </li>
          <li>
            <a href="/organizacion" class="block px-3 py-2 rounded-md text-sm font-semibold text-ugr-green hover:bg-ugr-green hover:text-white transition-all duration-200">
              Organización
            </a>
          </li>
          <li>
            <a href="/museo-memorias" class="block px-3 py-2 rounded-md text-sm font-semibold text-ugr-green hover:bg-ugr-green hover:text-white transition-all duration-200">
              Museo de Memorias Vivas
            </a>
          </li>
          <li>
            <a href="/programa" class="block px-3 py-2 rounded-md text-sm font-semibold text-ugr-green hover:bg-ugr-green hover:text-white transition-all duration-200">
              Programa
            </a>
          </li>
          <li>
            <a href="/contacto" class="block px-3 py-2 rounded-md text-sm font-semibold text-ugr-green hover:bg-ugr-green hover:text-white transition-all duration-200">
              Contacto
            </a>
          </li>
        </ul>

        <!-- Navegación móvil -->
        <ul id="mobile-nav" class="hidden md:hidden flex-col gap-1 mt-3 pb-2">
          <li>
            <a href="/" class="block px-4 py-3 rounded-lg text-sm font-semibold text-ugr-green hover:bg-ugr-green hover:text-white transition-all duration-200">
              Inicio
            </a>
          </li>
          <li>
            <a href="/el-simposio" class="block px-4 py-3 rounded-lg text-sm font-semibold text-ugr-green hover:bg-ugr-green hover:text-white transition-all duration-200">
              El Simposio
            </a>
          </li>
          <li>
            <a href="/organizacion" class="block px-4 py-3 rounded-lg text-sm font-semibold text-ugr-green hover:bg-ugr-green hover:text-white transition-all duration-200">
              Organización
            </a>
          </li>
          <li>
            <a href="/museo-memorias" class="block px-4 py-3 rounded-lg text-sm font-semibold text-ugr-green hover:bg-ugr-green hover:text-white transition-all duration-200">
              Museo de Memorias Vivas
            </a>
          </li>
          <li>
            <a href="/programa" class="block px-4 py-3 rounded-lg text-sm font-semibold text-ugr-green hover:bg-ugr-green hover:text-white transition-all duration-200">
              Programa
            </a>
          </li>
          <li>
            <a href="/contacto" class="block px-4 py-3 rounded-lg text-sm font-semibold text-ugr-green hover:bg-ugr-green hover:text-white transition-all duration-200">
              Contacto
            </a>
          </li>
        </ul>
      </nav>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const nav = document.getElementById('mobile-nav');
  btn?.addEventListener('click', () => {
    nav?.classList.toggle('hidden');
  });
</script>
